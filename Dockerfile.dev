FROM node:20-alpine

WORKDIR /app

# Copiar arquivos de configuração
COPY package*.json ./
COPY prisma ./prisma/

# Instalar dependências
RUN npm install

# Copiar código fonte
COPY src ./src/
COPY tsconfig*.json ./

# Gerar Prisma Client (após copiar src para não ser sobrescrito)
RUN npx prisma generate

# Expor porta
EXPOSE 3000

# Comando de desenvolvimento
CMD ["npx", "tsx", "watch", "src/server.ts"]
